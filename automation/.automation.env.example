# 자동화 설정 — 이 파일을 복사해 `.automation.env` 로 저장하고 값을 채우세요.
# (.automation.env 는 .gitignore 처리되어 커밋되지 않습니다.)

# 텔레그램 알림용 (선택). BotFather에서 봇 생성 후 토큰 발급, chat_id는 봇에게 메시지 보내면 확인.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 배포 대상 Cloudflare Pages 프로젝트명 (wrangler.toml의 name과 동일)
CF_PROJECT_NAME=your-project-name

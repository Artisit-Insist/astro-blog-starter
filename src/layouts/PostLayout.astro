---
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';
import type { Post } from '../utils.ts';
import { formatDate, readingTime, stickerColor, getRelatedPosts } from '../utils.ts';
import { SITE, AUTHOR } from '../consts.ts';

interface Props {
  post: Post;
}
const { post } = Astro.props;
const related = await getRelatedPosts(post, 3);
const { title, description, pubDate, updatedDate, tags, keywords, tldr, heroImage, heroAlt, ogImage } =
  post.data;

const url = new URL(`/blog/${post.id}/`, SITE.url).href;
const mins = readingTime(post.body);
// 글 전용 OG 이미지 (자동생성). 명시적 ogImage가 있으면 우선.
const ogUrl = ogImage ?? `/og/${post.id}.png`;

// BlogPosting 구조화 데이터 (검색 리치결과 + GEO)
const articleLd = {
  '@type': 'BlogPosting',
  '@id': `${url}#article`,
  headline: title,
  description,
  inLanguage: SITE.lang,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@id': `${SITE.url}/#person` },
  publisher: { '@id': `${SITE.url}/#organization` },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  keywords: [...tags, ...keywords].join(', '),
  image: new URL(ogUrl, SITE.url).href,
};

const breadcrumbLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: '글', item: `${SITE.url}/blog` },
    { '@type': 'ListItem', position: 3, name: title, item: url },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  image={ogUrl}
  publishedTime={pubDate}
  modifiedTime={updatedDate ?? pubDate}
  keywords={[...tags, ...keywords]}
  jsonLd={[articleLd, breadcrumbLd]}
>
  <article class="container">
    <nav class="crumbs" aria-label="위치">
      <a href="/">홈</a> <span>/</span> <a href="/blog">글</a>
    </nav>

    <header class="post-header">
      <div class="meta">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        <span>· {mins}분 읽기</span>
        {updatedDate && <span>· 업데이트 {formatDate(updatedDate)}</span>}
      </div>
      <h1>{title}</h1>
      <p class="lead">{description}</p>
      {
        tags.length > 0 && (
          <div class="tags">
            {tags.map((t) => (
              <a href={`/tags/${encodeURIComponent(t)}`} class="tag-pill">
                <i class="dot" style={`background:${stickerColor(t)}`} />
                {t}
              </a>
            ))}
          </div>
        )
      }
    </header>

    {
      heroImage && (
        <Image class="hero" src={heroImage} alt={heroAlt ?? title} width={1200} height={630} />
      )
    }

    {
      tldr && (
        <aside class="tldr" aria-label="핵심 요약">
          <span class="tldr-label">핵심 요약</span>
          <p>{tldr}</p>
        </aside>
      )
    }

    <div class="prose">
      <slot />
    </div>

    {
      related.length > 0 && (
        <section class="related" aria-label="관련 글">
          <h2>관련 글</h2>
          <ul>
            {related.map((r) => (
              <li>
                <a href={`/blog/${r.id}`}>
                  {r.data.tags[0] && (
                    <span class="rdot" style={`background:${stickerColor(r.data.tags[0])}`} />
                  )}
                  <span class="rtitle">{r.data.title}</span>
                  <time datetime={r.data.pubDate.toISOString()}>{formatDate(r.data.pubDate)}</time>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <footer class="post-footer">
      <div class="byline">
        <img src={AUTHOR.avatar} alt={AUTHOR.name} width="52" height="52" />
        <div>
          <strong>{AUTHOR.name}</strong>
          <p>{AUTHOR.role}</p>
        </div>
      </div>
      <a href="/blog" class="btn btn-ghost">← 다른 글 보기</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .crumbs {
    margin: 32px 0 0;
    font-size: 0.85rem;
    color: var(--text-faint);
  }
  .crumbs a {
    color: var(--text-faint);
  }
  .crumbs a:hover {
    color: var(--text);
  }
  .crumbs span {
    margin: 0 0.4em;
  }
  .post-header {
    margin: 20px 0 32px;
  }
  .post-header .meta {
    display: flex;
    gap: 0.4em;
    flex-wrap: wrap;
    color: var(--text-faint);
    font-size: 0.875rem;
  }
  .post-header h1 {
    margin: 0.45em 0 0.4em;
    font-size: clamp(1.9rem, 5vw, 2.75rem);
    line-height: 1.08;
    letter-spacing: -0.033em;
  }
  .lead {
    margin: 0;
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1.55;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 1.2em;
  }
  .tag-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    padding: 3px 12px;
    border-radius: 9999px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-secondary);
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
  }
  .tag-pill:hover {
    text-decoration: none;
    box-shadow: var(--shadow);
    color: var(--text);
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    display: inline-block;
  }
  .hero {
    width: 100%;
    height: auto;
    border-radius: var(--rounded-xl);
    border: 1px solid var(--border);
    margin-bottom: 32px;
  }
  .tldr {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--rounded-lg);
    padding: 18px 22px;
    margin-bottom: 36px;
    box-shadow: var(--shadow);
  }
  .tldr-label {
    display: inline-block;
    font-weight: 600;
    color: var(--brand);
    font-size: 0.75rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin-bottom: 0.4em;
  }
  .tldr p {
    margin: 0;
    font-size: 0.98rem;
    color: var(--text-secondary);
  }
  .related {
    margin-top: 56px;
    padding-top: 28px;
    border-top: 1px solid var(--border);
  }
  .related h2 {
    font-size: 1.15rem;
    letter-spacing: -0.02em;
    margin-bottom: 14px;
  }
  .related ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .related li + li {
    border-top: 1px solid var(--border);
  }
  .related a {
    display: flex;
    align-items: center;
    gap: 0.7em;
    padding: 12px 4px;
    text-decoration: none;
    color: var(--text);
  }
  .related a:hover .rtitle {
    color: var(--brand);
  }
  .rdot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .rtitle {
    flex: 1;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .related time {
    color: var(--text-faint);
    font-size: 0.82rem;
    white-space: nowrap;
  }

  .post-footer {
    margin-top: 64px;
    padding-top: 28px;
    border-top: 1px solid var(--border);
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    align-items: center;
    justify-content: space-between;
  }
  .byline {
    display: flex;
    gap: 0.9rem;
    align-items: center;
  }
  .byline img {
    border-radius: 50%;
    object-fit: cover;
  }
  .byline strong {
    display: block;
    letter-spacing: -0.01em;
  }
  .byline p {
    margin: 0.15em 0 0;
    color: var(--text-muted);
    font-size: 0.85rem;
  }
</style>

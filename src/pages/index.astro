---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeaturedPost from '../components/FeaturedPost.astro';
import PostRow from '../components/PostRow.astro';
import { AUTHOR, SERVICE, SITE } from '../consts.ts';
import { getPublishedPosts } from '../utils.ts';

const allPosts = await getPublishedPosts();
const [latest, ...more] = allPosts;
const recent = more.slice(0, 5);
---

<BaseLayout title={SITE.title} description={SITE.description}>
  <!-- ① 최신 글 — 첫 화면 최상단 -->
  {
    latest && (
      <section class="latest container-wide">
        <FeaturedPost post={latest} eyebrow="오늘의 글" />
      </section>
    )
  }

  <!-- ② 최근 글 피드 -->
  {
    recent.length > 0 && (
      <section class="recent container">
        <div class="recent-head">
          <h2>최근 글</h2>
          <a href="/blog">전체 보기 →</a>
        </div>
        <div class="rows">
          {recent.map((post) => (
            <PostRow post={post} />
          ))}
        </div>
      </section>
    )
  }

  <!-- ③ 소개 밴드 (간결하게, 하단) -->
  <section class="about container">
    <div class="about-card">
      <img src={AUTHOR.avatar} alt={`${AUTHOR.name} 프로필 사진`} width="88" height="118" />
      <div class="about-text">
        <p class="who">
          {AUTHOR.role}
          <span class="dots" aria-hidden="true">
            <i style="background:var(--sticker-sky)"></i>
            <i style="background:var(--sticker-pink)"></i>
            <i style="background:var(--sticker-teal)"></i>
          </span>
        </p>
        <h2>안녕하세요, {AUTHOR.name}입니다.</h2>
        <p class="bio">
          {AUTHOR.bio} <strong>{SERVICE.name}</strong> — {SERVICE.tagline}
          {SERVICE.subTagline}
        </p>
        <div class="cta">
          <a href="/blog" class="btn btn-primary">글 보러 가기</a>
          <a href="/about" class="btn btn-ghost">더 알아보기</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .latest {
    padding-top: 40px;
  }
  .recent {
    padding-top: 56px;
  }
  .recent-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 4px;
  }
  .recent-head h2 {
    font-size: 1.35rem;
    letter-spacing: -0.02em;
  }
  .recent-head a {
    font-size: 0.9rem;
    font-weight: 500;
  }
  .about {
    padding-top: 64px;
  }
  .about-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--rounded-xl);
    padding: 36px 40px;
    display: flex;
    gap: 28px;
    align-items: center;
  }
  .about-card img {
    border-radius: var(--rounded-lg);
    object-fit: cover;
    flex-shrink: 0;
  }
  .who {
    margin: 0 0 0.5em;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.6em;
  }
  .dots {
    display: inline-flex;
    gap: 4px;
  }
  .dots i {
    width: 7px;
    height: 7px;
    border-radius: 50%;
  }
  .about-text h2 {
    font-size: 1.5rem;
    letter-spacing: -0.025em;
    margin-bottom: 0.45em;
  }
  .bio {
    margin: 0 0 1.3em;
    color: var(--text-muted);
    font-size: 0.97rem;
    line-height: 1.6;
  }
  .cta {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  @media (max-width: 620px) {
    .about-card {
      flex-direction: column;
      align-items: flex-start;
      padding: 28px 24px;
    }
  }
</style>

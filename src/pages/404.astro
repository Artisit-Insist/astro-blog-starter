---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="페이지를 찾을 수 없어요" noindex={true}>
  <section class="container nf">
    <p class="code">404</p>
    <h1>페이지를 찾을 수 없어요</h1>
    <p class="desc">주소가 바뀌었거나 삭제된 글일 수 있습니다.</p>
    <div class="cta">
      <a href="/" class="btn btn-primary">홈으로</a>
      <a href="/blog" class="btn btn-ghost">글 목록</a>
    </div>
  </section>
</BaseLayout>

<style>
  .nf {
    text-align: center;
    padding: 5rem 0;
  }
  .code {
    font-size: 4rem;
    font-weight: 800;
    color: var(--brand);
    margin: 0;
  }
  .nf h1 {
    margin: 0.2em 0;
  }
  .desc {
    color: var(--text-muted);
  }
  .cta {
    display: flex;
    gap: 0.7rem;
    justify-content: center;
    margin-top: 1.5rem;
  }
</style>

---
import { SITE, AUTHOR, SERVICE, VERIFICATION } from '../consts.ts';

interface Props {
  title: string;
  description?: string;
  image?: string;
  /** 'website' | 'article' */
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  keywords?: string[];
  /** 이 페이지에 추가로 넣을 JSON-LD 객체들 */
  jsonLd?: Record<string, unknown>[];
  noindex?: boolean;
}

const {
  title,
  description = SITE.description,
  image = SITE.defaultOgImage,
  type = 'website',
  publishedTime,
  modifiedTime,
  keywords = [],
  jsonLd = [],
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site).href;
const fullTitle = title === SITE.title ? title : `${title} | ${SITE.title}`;

// 모든 페이지 공통: 저자(Person) + 서비스(Organization) + 사이트(WebSite)
const sameAs = [
  AUTHOR.social.linkedin,
  AUTHOR.social.brunch,
  AUTHOR.social.instagram,
  AUTHOR.social.youtube,
].filter(Boolean);

const personLd = {
  '@type': 'Person',
  '@id': `${SITE.url}/#person`,
  name: AUTHOR.name,
  alternateName: AUTHOR.nameEn,
  description: AUTHOR.bio,
  jobTitle: AUTHOR.role,
  image: new URL(AUTHOR.avatar, SITE.url).href,
  url: SITE.url,
  ...(sameAs.length > 0 ? { sameAs } : {}),
  worksFor: { '@id': `${SITE.url}/#organization` },
};

const orgLd = {
  '@type': 'Organization',
  '@id': `${SITE.url}/#organization`,
  name: SERVICE.name,
  alternateName: SERVICE.nameEn,
  description: SERVICE.description,
  slogan: SERVICE.tagline,
  url: SERVICE.url || SITE.url,
  founder: { '@id': `${SITE.url}/#person` },
};

const websiteLd = {
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  name: SITE.title,
  description: SITE.description,
  url: SITE.url,
  inLanguage: SITE.lang,
  publisher: { '@id': `${SITE.url}/#person` },
};

const graph = [personLd, orgLd, websiteLd, ...jsonLd];
const structuredData = { '@context': 'https://schema.org', '@graph': graph };
---

<!-- 기본 메타 -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<link rel="canonical" href={canonicalURL} />

{VERIFICATION.google && <meta name="google-site-verification" content={VERIFICATION.google} />}
{VERIFICATION.naver && <meta name="naver-site-verification" content={VERIFICATION.naver} />}

<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
<meta name="author" content={AUTHOR.name} />
{keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
{noindex && <meta name="robots" content="noindex, nofollow" />}
{!noindex && <meta name="robots" content="index, follow, max-image-preview:large" />}

<!-- 파비콘 -->
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/face.png" />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE.title} />
<meta property="og:locale" content={SITE.locale} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={ogImageURL} />
{publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

<!-- RSS -->
<link rel="alternate" type="application/rss+xml" title={SITE.title} href={new URL('/rss.xml', Astro.site)} />

<!-- 구조화 데이터 (JSON-LD) -->
<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

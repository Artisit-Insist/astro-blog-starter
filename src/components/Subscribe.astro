---
// 이메일 구독 폼 — /api/subscribe 로 저장
interface Props {
  source?: string;
}
const { source = 'site' } = Astro.props;
---

<section class="subscribe container">
  <div class="sub-card">
    <div class="sub-text">
      <h2>새 글, 가장 먼저 받아보기</h2>
      <p>새 글이 올라오면 이메일로 알려드립니다.</p>
    </div>
    <form id="subForm" class="sub-form" data-source={source}>
      <input
        id="subEmail"
        type="email"
        name="email"
        required
        placeholder="이메일 주소"
        autocomplete="email"
        aria-label="이메일 주소"
      />
      <button type="submit" class="btn btn-primary">구독</button>
    </form>
    <p id="subMsg" class="sub-msg" hidden></p>
  </div>
</section>

<script is:inline>
  (function () {
    var f = document.getElementById('subForm');
    if (!f) return;
    var msg = document.getElementById('subMsg');
    f.addEventListener('submit', async function (e) {
      e.preventDefault();
      var email = document.getElementById('subEmail').value.trim();
      var btn = f.querySelector('button');
      btn.disabled = true;
      msg.hidden = true;
      try {
        var res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, source: f.dataset.source }),
        });
        var data = await res.json();
        if (res.ok) {
          msg.textContent = data.duplicate ? '이미 구독 중이세요. 감사합니다!' : '구독 완료! 새 글로 찾아뵐게요.';
          msg.className = 'sub-msg ok';
          f.reset();
        } else {
          msg.textContent = data.error === 'invalid_email' ? '이메일 주소를 확인해주세요.' : '잠시 후 다시 시도해주세요.';
          msg.className = 'sub-msg err';
        }
      } catch (err) {
        msg.textContent = '잠시 후 다시 시도해주세요.';
        msg.className = 'sub-msg err';
      } finally {
        msg.hidden = false;
        btn.disabled = false;
      }
    });
  })();
</script>

<style>
  .subscribe {
    padding-top: 64px;
  }
  .sub-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--rounded-xl);
    padding: 32px 36px;
    display: flex;
    flex-wrap: wrap;
    gap: 20px 32px;
    align-items: center;
    justify-content: space-between;
  }
  .sub-text h2 {
    font-size: 1.3rem;
    letter-spacing: -0.02em;
    margin-bottom: 0.3em;
  }
  .sub-text p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .sub-form {
    display: flex;
    gap: 8px;
    flex: 1 1 300px;
    max-width: 420px;
  }
  .sub-form input {
    flex: 1;
    padding: 0.7em 1em;
    border-radius: 9999px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text);
    font-size: 0.95rem;
    font-family: inherit;
    min-width: 0;
  }
  .sub-form input:focus {
    outline: 2px solid var(--brand);
    border-color: var(--brand);
  }
  .sub-msg {
    flex-basis: 100%;
    margin: 4px 0 0;
    font-size: 0.88rem;
  }
  .sub-msg.ok {
    color: var(--sticker-green);
  }
  .sub-msg.err {
    color: #d33;
  }
</style>

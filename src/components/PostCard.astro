---
import type { Post } from '../utils.ts';
import { formatDate, stickerColor } from '../utils.ts';
import { Image } from 'astro:assets';

interface Props {
  post: Post;
}
const { post } = Astro.props;
const { title, description, pubDate, tags, heroImage, heroAlt } = post.data;
const href = `/blog/${post.id}`;
---

<article class="card">
  {
    heroImage && (
      <a href={href} class="thumb" tabindex="-1" aria-hidden="true">
        <Image src={heroImage} alt={heroAlt ?? ''} width={720} height={380} />
      </a>
    )
  }
  <div class="body">
    <div class="meta">
      <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
      {
        tags[0] && (
          <span class="cat">
            <i class="dot" style={`background:${stickerColor(tags[0])}`} />
            {tags[0]}
          </span>
        )
      }
    </div>
    <h2><a href={href}>{title}</a></h2>
    <p class="desc">{description}</p>
    <a href={href} class="more">글 읽기 →</a>
  </div>
</article>

<style>
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--rounded-lg);
    overflow: hidden;
    transition: box-shadow 0.15s ease;
  }
  .card:hover {
    box-shadow: var(--shadow);
  }
  .thumb :global(img) {
    width: 100%;
    height: 190px;
    object-fit: cover;
  }
  .body {
    padding: 22px 24px 24px;
  }
  .meta {
    display: flex;
    gap: 0.7em;
    align-items: center;
    color: var(--text-faint);
    font-size: 0.82rem;
    margin-bottom: 0.5em;
  }
  .cat {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    color: var(--text-muted);
    font-weight: 500;
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    display: inline-block;
  }
  h2 {
    margin: 0 0 0.4em;
    font-size: 1.2rem;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }
  h2 a {
    color: var(--text);
    text-decoration: none;
  }
  h2 a:hover {
    color: var(--brand);
    text-decoration: none;
  }
  .desc {
    margin: 0 0 1em;
    color: var(--text-muted);
    font-size: 0.93rem;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .more {
    font-weight: 500;
    font-size: 0.9rem;
  }
</style>
